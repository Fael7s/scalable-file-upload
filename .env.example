# AWS
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=my-file-upload-bucket

# App
APP_NAME=ScalableFileUpload
APP_ENV=development
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,txt,csv,zip
PRESIGNED_URL_EXPIRATION=3600

# Database
DATABASE_URL=sqlite+aiosqlite:///./file_upload.db

# Auth (API Key simples para demonstração)
API_KEY=your-secret-api-key-here
